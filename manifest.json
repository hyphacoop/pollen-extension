{
  "manifest_version": 3,
  "name": "Pollen",
  "description": "Surface image provenance claims on Bluesky",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "hello@hypha.coop"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://bsky.app/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "permissions": []
}
